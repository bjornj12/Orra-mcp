{
  "name": "orra-mcp",
  "version": "0.4.0",
  "description": "MCP server that turns Claude Code into a multi-agent orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orra-mcp": "dist/index.js",
    "orra-setup": "dist/bin/setup.js",
    "orra-session-start-hook": "dist/bin/session-start-hook.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && mkdir -p dist/templates/directives dist/templates/memory && cp src/templates/orchestrator.md dist/templates/orchestrator.md && cp src/templates/directives/*.md dist/templates/directives/ && cp src/templates/memory/*.md dist/templates/memory/ && chmod +x dist/index.js dist/bin/setup.js dist/bin/session-start-hook.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "verify": "bash scripts/verify-publish.sh",
    "link:dev": "npm run build && npm link",
    "unlink:dev": "npm unlink -g orra-mcp",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjornj12/Orra-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/bjornj12/Orra-mcp/issues"
  },
  "homepage": "https://github.com/bjornj12/Orra-mcp#readme",
  "author": {
    "name": "Bjorn Olafur",
    "email": "bjorn.olafur@gmail.com"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "orchestrator",
    "agents",
    "multi-agent",
    "worktree",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
